# ─────────────────────────────────────────────
# n8n · Core
# ─────────────────────────────────────────────

# Public hostname for the n8n instance (no protocol, no trailing slash)
N8N_HOST=n8n.yourdomain.com

# Protocol exposed to users (https recommended)
N8N_PROTOCOL=https

# Full public URL used for webhooks (must match N8N_HOST)
WEBHOOK_URL=https://n8n.yourdomain.com/

# Pinned n8n image version · use a specific tag in production
# See: https://hub.docker.com/r/n8nio/n8n/tags
N8N_VERSION=latest

# Secret key used to encrypt credentials stored in n8n
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_generate_a_random_key

# ─────────────────────────────────────────────
# n8n · Authentication
# ─────────────────────────────────────────────

# Set to true to enable HTTP Basic Auth (useful before user management is set up)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me

# Set to true to completely disable user management (single-user mode)
N8N_USER_MANAGEMENT_DISABLED=false

# ─────────────────────────────────────────────
# n8n · Database
# ─────────────────────────────────────────────

# sqlite (default, no extra config needed) | postgresdb
DB_TYPE=sqlite

# PostgreSQL · only required when DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change_me

# ─────────────────────────────────────────────
# n8n · Executions
# ─────────────────────────────────────────────

# Automatically delete old execution logs
EXECUTIONS_DATA_PRUNE=true

# Maximum age of execution data in hours (336 = 14 days)
EXECUTIONS_DATA_MAX_AGE=336

# ─────────────────────────────────────────────
# n8n · Email / SMTP (optional)
# ─────────────────────────────────────────────

# Set to "smtp" to enable outgoing email (password reset, invites)
N8N_EMAIL_MODE=
N8N_SMTP_HOST=
N8N_SMTP_PORT=587
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=n8n@yourdomain.com

# ─────────────────────────────────────────────
# Timezone
# ─────────────────────────────────────────────

# IANA timezone identifier · affects cron triggers and log timestamps
GENERIC_TIMEZONE=Europe/Paris

# ─────────────────────────────────────────────
# Traefik
# ─────────────────────────────────────────────

# Traefik entrypoint name configured on your proxy (usually websecure for HTTPS)
TRAEFIK_ENTRYPOINT=websecure

# Certificate resolver name defined in your Traefik static config
TRAEFIK_CERT_RESOLVER=letsencrypt
